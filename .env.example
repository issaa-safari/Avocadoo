# Supabase project connection — copy this file to .env.local and fill in real values.
# Find these in your Supabase project dashboard: Settings -> API.

# Project URL (Settings -> API -> Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Publishable / anon key (Settings -> API -> Project API keys -> "anon" / "publishable")
# Safe to expose in the browser — RLS policies are what actually protect the data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret service_role key (Settings -> API -> Project API keys -> "service_role")
# SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_. Bypasses RLS — only used from
# trusted server code (e.g. scheduled jobs, admin tooling), never from the browser.
SUPABASE_SERVICE_ROLE_KEY=
